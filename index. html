    <script>
        // GSAP Animations
        gsap.registerPlugin(ScrollTrigger);
        
        // Animate sections on scroll
        gsap.utils.toArray('.glass-panel').forEach((panel, i) => {
            gsap.from(panel, {
                scrollTrigger: {
                    trigger: panel,
                    start: "top 85%",
                },
                y: 50,
                opacity: 0,
                duration: 0.8,
                delay: i * 0.1,
                ease: "power3.out"
            });
        });

        // Calculator Logic
        let selectedGripStyle = 'palm';
        
        function selectGrip(grip) {
            selectedGripStyle = grip;
            document.querySelectorAll('.grip-btn').forEach(btn => {
                btn.classList.remove('bg-cyan-500/20', 'border-cyan-500');
                btn.classList.add('bg-gray-800', 'border-gray-700');
            });
            event.target.classList.remove('bg-gray-800', 'border-gray-700');
            event.target.classList.add('bg-cyan-500/20', 'border-cyan-500');
            
            const gripNames = { palm: 'Palm Grip', claw: 'Claw Grip', fingertip: 'Fingertip Grip' };
            document.getElementById('gripValue').textContent = gripNames[grip];
        }

        // Initialize palm as selected
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelector('[data-grip="palm"]').classList.add('bg-cyan-500/20', 'border-cyan-500');
            document.querySelector('[data-grip="palm"]').classList.remove('bg-gray-800', 'border-gray-700');
        });

        function calculateSensitivity() {
            const genre = document.getElementById('gameGenre').value;
            const dpiRange = document.getElementById('dpiRange').value;
            const screenRes = document.getElementById('screenRes').value;
            
            // Base calculations based on research
            let baseDPI = 800;
            let baseSens = 0.5;
            
            // Genre adjustments
            const genreMultipliers = {
                fps: { dpi: 0.8, sens: 0.6 },      // Lower DPI for precision
                battleroyale: { dpi: 1.0, sens: 0.8 },
                moba: { dpi: 1.2, sens: 1.0 },
                strategy: { dpi: 1.4, sens: 1.2 }
            };
            
            // DPI range adjustments
            const dpiRanges = {
                low: 600,
                medium: 800,
                high: 1600
            };
            
            baseDPI = dpiRanges[dpiRange];
            baseSens = genreMultipliers[genre].sens;
            
            // Grip adjustment
            const gripMultipliers = {
                palm: 0.9,      // More control, slightly lower sens
                claw: 1.0,      // Balanced
                fingertip: 1.1  // Faster movements
            };
            
            baseSens *= gripMultipliers[selectedGripStyle];
            
            // Calculate eDPI and cm/360
            const edpi = Math.round(baseDPI * baseSens);
            const cm360 = Math.round((360 / (edpi * 0.022)) * 2.54); // Rough calculation
            
            // Display results
            document.getElementById('recDPI').textContent = baseDPI;
            document.getElementById('recSens').textContent = baseSens.toFixed(2);
            document.getElementById('recEdpi').textContent = edpi;
            document.getElementById('recCm').textContent = cm360 + 'cm';
            
            // Show results with animation
            const results = document.getElementById('calcResults');
            results.classList.remove('hidden');
            gsap.from(results, { height: 0, opacity: 0, duration: 0.5, ease: "power2.out" });
            
            // Scroll to results
            results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // Modal Functions
        function selectPackage(pkg) {
            document.getElementById('selectedPackage').value = pkg;
            openModal();
        }

        function openModal() {
            document.getElementById('bookingModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            gsap.from('#bookingModal > div:last-child', { scale: 0.9, opacity: 0, duration: 0.3 });
        }

        function closeModal() {
            document.getElementById('bookingModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
            // Reset form
            setTimeout(() => {
                document.getElementById('bookingForm').classList.remove('hidden');
                document.getElementById('successMessage').classList.add('hidden');
                document.getElementById('bookingForm').reset();
            }, 300);
        }

        function submitBooking(e) {
            e.preventDefault();
            
            // Simulate form submission
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="animate-spin">↻</span> Processing...';
            btn.disabled = true;
            
            setTimeout(() => {
                document.getElementById('bookingForm').classList.add('hidden');
                document.getElementById('successMessage').classList.remove('hidden');
                gsap.from('#successMessage', { opacity: 0, y: 20, duration: 0.5 });
                
                // In production, this would send data to your backend/email service
                console.log('Booking submitted:', {
                    name: document.getElementById('clientName').value,
                    email: document.getElementById('clientEmail').value,
                    package: document.getElementById('selectedPackage').value,
                    game: document.getElementById('primaryGame').value
                });
            }, 1500);
        }

        // Smooth scroll functions
        function scrollToCalculator() {
            document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
        }

        function scrollToBooking() {
            document.getElementById('consultation').scrollIntoView({ behavior: 'smooth' });
        }

        // Screen resolution slider
        document.getElementById('screenRes').addEventListener('input', (e) => {
            const values = ['1920x1080', '2560x1440', '3840x2160', '3440x1440'];
            document.getElementById('resValue').textContent = values[e.target.value - 1];
        });
    </script>
